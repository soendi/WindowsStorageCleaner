<?xml version="1.0" encoding="UTF-8"?>
    <Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
         xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
        <Package Name="Windows Storage Cleaner"
                 Manufacturer="Lukas Sonderegger"
                  Version="1.2.4.0"
                 UpgradeCode="12345678-1234-1234-1234-123456789abc"
                 Scope="perMachine">
            <Icon Id="AppIcon" SourceFile="..\Publish\app.ico" />
            <Property Id="ARPPRODUCTICON" Value="AppIcon" />

            <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed."
                          AllowSameVersionUpgrades="yes"
                          Schedule="afterInstallValidate" />
            <MediaTemplate EmbedCab="yes" />

            <Property Id="DOTNET8DESKTOP" Secure="yes">
                <RegistrySearch Id="FindNet8Desktop"
                                Root="HKLM"
                                Key="SOFTWARE\dotnet\Setup\InstalledVersions\x64\Microsoft.WindowsDesktop.App"
                                Type="raw" />
            </Property>

            <Property Id="ARPHELPLINK" Value="https://github.com/sonde/WindowsStorageCleaner" />
            <Property Id="ARPURLINFOABOUT" Value="https://github.com/sonde/WindowsStorageCleaner" />
            <Property Id="ARPCOMMENTS" Value="Windows Storage Cleaner - Speicherplatzbereinigung" />
            <Property Id="ARPURLUPDATEINFO" Value="https://github.com/sonde/WindowsStorageCleaner/releases" />

            <Property Id="ApplicationFolderName" Value="WindowsStorageCleaner" />
            <Property Id="WixAppFolder" Value="WixPerMachineFolder" />

            <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />
            <ui:WixUI Id="WixUI_FeatureTree" />

            <Feature Id="MainFeature"
                     Title="Windows Storage Cleaner"
                     Description="Installs the Windows Storage Cleaner application"
                     Level="1"
                     ConfigurableDirectory="INSTALLFOLDER">
                <ComponentGroupRef Id="ProductComponents" />
                <ComponentRef Id="ApplicationShortcut" />
            </Feature>

            <Feature Id="DesktopShortcutFeature"
                     Title="Desktop Shortcut"
                     Description="Creates a shortcut on the desktop"
                     Level="1">
                <ComponentRef Id="DesktopShortcut" />
            </Feature>

            <StandardDirectory Id="ProgramFiles64Folder">
                <Directory Id="INSTALLFOLDER" Name="WindowsStorageCleaner" />
            </StandardDirectory>

            <StandardDirectory Id="ProgramMenuFolder">
                <Directory Id="ApplicationProgramsFolder" Name="Windows Storage Cleaner">
                    <Component Id="ApplicationShortcut" Guid="12345678-1234-1234-1234-123456789abd">
                        <Shortcut Id="ApplicationStartMenuShortcut"
                                  Name="Windows Storage Cleaner"
                                  Description="Professional disk cleanup utility"
                                  Target="[#WindowsStorageCleanerEXE]"
                                  WorkingDirectory="INSTALLFOLDER" />
                        <RegistryValue Root="HKCU"
                                       Key="Software\WindowsStorageCleaner"
                                       Name="installed"
                                       Type="integer"
                                       Value="1"
                                       KeyPath="yes" />
                        <RemoveFolder Id="RemoveApplicationProgramsFolder"
                                      On="uninstall" />
                    </Component>
                </Directory>
            </StandardDirectory>

            <StandardDirectory Id="DesktopFolder">
                <Component Id="DesktopShortcut" Guid="12345678-1234-1234-1234-123456789ac5">
                    <Shortcut Id="ApplicationDesktopShortcut"
                              Name="Windows Storage Cleaner"
                              Description="Professional disk cleanup utility"
                              Target="[#WindowsStorageCleanerEXE]"
                              WorkingDirectory="INSTALLFOLDER" />
                    <RegistryValue Root="HKCU"
                                   Key="Software\WindowsStorageCleaner"
                                   Name="desktop_shortcut"
                                   Type="integer"
                                   Value="1"
                                   KeyPath="yes" />
                </Component>
            </StandardDirectory>

            <ComponentGroup Id="ProductComponents">
                <Component Id="MainExecutable" Directory="INSTALLFOLDER" Guid="12345678-1234-1234-1234-123456789abe">
                    <File Id="WindowsStorageCleanerEXE"
                          Source="..\Publish\WindowsStorageCleaner.exe"
                          Name="WindowsStorageCleaner.exe"
                          KeyPath="yes" />
<?ifdef RUNTIME_INCLUDED ?>
                    <File Id="D3DCompilerDLL"
                          Source="..\Publish\D3DCompiler_47_cor3.dll" />
                    <File Id="PenImcDLL"
                          Source="..\Publish\PenImc_cor3.dll" />
                    <File Id="PresentationNativeDLL"
                          Source="..\Publish\PresentationNative_cor3.dll" />
                    <File Id="VCRuntimeDLL"
                          Source="..\Publish\vcruntime140_cor3.dll" />
                    <File Id="WpfGfxDLL"
                          Source="..\Publish\wpfgfx_cor3.dll" />
<?endif ?>
                </Component>
                <Component Id="AppIcon" Directory="INSTALLFOLDER" Guid="12345678-1234-1234-1234-123456789ac6">
                    <File Id="AppIconFile"
                          Source="..\Publish\app.ico"
                          Name="app.ico"
                          KeyPath="yes" />
                </Component>
            </ComponentGroup>

            <!-- Launch app after install (like KOFplanner's Inno Setup [Run] section) -->
            <CustomAction Id="LaunchApp" FileRef="WindowsStorageCleanerEXE" ExeCommand=""
                          Execute="immediate" Return="asyncNoWait" />
            <InstallExecuteSequence>
                <Custom Action="LaunchApp" After="InstallFinalize" Condition="NOT Installed" />
            </InstallExecuteSequence>
        </Package>
    </Wix>
