<Window x:Class="WindowsStorageCleaner.Views.ShortcutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Desktop-Verknüpfung erstellen"
        Width="420" MinHeight="200" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Verknüpfung erstellen" FontSize="20" FontWeight="Bold"
                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1" Text="Wählen Sie die Startparameter für die Desktop-Verknüpfung:"
                   TextWrapping="Wrap" Margin="0,0,0,12"/>

        <ComboBox x:Name="ProfileCombo" Grid.Row="2" Height="30" FontSize="13"
                  Style="{DynamicResource ComboBoxStyle}" Margin="0,0,0,16"/>

        <Button Grid.Row="4" Content="&#x1F4C1; Verknüpfung auf dem Desktop hinzufügen"
                Height="36" FontSize="13" FontWeight="Bold"
                Style="{DynamicResource AccentButtonStyle}"
                Click="OnCreateShortcut" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="5" Text="Die Verknüpfung startet Windows Storage Cleaner mit den gewählten Parametern. Bei --profile läuft die Bereinigung ohne sichtbares Fenster."
                   TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,12"/>

        <Button Grid.Row="6" Content="Schließen" Width="100" Height="32"
                HorizontalAlignment="Right"
                Style="{DynamicResource ActionButtonStyle}" Click="OnCloseClick"/>
    </Grid>
</Window>
