<Window x:Class="WindowsStorageCleaner.Views.UpdateProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update wird heruntergeladen"
        Width="380" Height="140" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Update wird heruntergeladen..." FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>
        <ProgressBar x:Name="ProgressBar" Grid.Row="1" Height="24" Minimum="0" Maximum="100" Margin="0,0,0,6"/>
        <TextBlock x:Name="PercentText" Grid.Row="2" Text="0%" FontSize="12" HorizontalAlignment="Center"
                   Foreground="{DynamicResource SecondaryTextBrush}"/>
    </Grid>
</Window>
