<Window x:Class="WindowsStorageCleaner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:WindowsStorageCleaner.Converters"
        Title="Windows Storage Cleaner"
        Width="1400" Height="1000"
        MinWidth="1000" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Closing="OnWindowClosing">
    <Window.Resources>
        <ResourceDictionary>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
            <conv:ThemeIconConverter x:Key="ThemeIconConverter"/>
            <conv:AdminTextConverter x:Key="AdminTextConverter"/>
            <conv:AdminBgConverter x:Key="AdminBgConverter"/>
            <conv:AdminFgConverter x:Key="AdminFgConverter"/>
            <conv:LogLevelToColorConverter x:Key="LogLevelConverter"/>
            <conv:BoolToIndentConverter x:Key="IndentConverter"/>
            <conv:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyConverter"/>
            <Style TargetType="ToolTip">
                <Setter Property="Background" Value="{DynamicResource ToolTipBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource ToolTipForegroundBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Padding" Value="6,3"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" CornerRadius="6" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="&#x1F5C2;" FontSize="28" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="Windows Storage Cleaner" FontSize="22" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Professionelle Speicherplatzbereinigung" FontSize="11" Foreground="#DDD"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="&#x1F319;" Width="36" Height="36" FontSize="18"
                            ToolTip="Design umschalten" Style="{DynamicResource IconButtonStyle}"
                            Click="OnThemeToggleClick" Margin="0,0,5,0"/>
                    <Button Content="?" Width="36" Height="36" FontSize="18" FontWeight="Bold"
                            ToolTip="Alle Bereinigungspunkte" Style="{DynamicResource IconButtonStyle}"
                            Click="OnCleanupInfoClick" Margin="0,0,5,0"/>
                    <Button Content="&#x2139;" Width="36" Height="36" FontSize="18"
                            ToolTip="Über" Style="{DynamicResource IconButtonStyle}"
                            Click="OnAboutClick" Margin="0,0,5,0"/>
                    <Button Content="&#x21BB;" Width="36" Height="36" FontSize="18"
                            ToolTip="Nach Updates suchen" Style="{DynamicResource IconButtonStyle}"
                            Click="OnUpdateCheckClick" Margin="0,0,5,0"/>
                    <Button Content="&#x1F4C5;" Width="36" Height="36" FontSize="16"
                            ToolTip="Automatische Bereinigung" Style="{DynamicResource IconButtonStyle}"
                            Click="OnScheduledCleanupClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- System Info Bar -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0">
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="{Binding SystemInfo.OsName}" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="{Binding SystemInfo.BuildNumber, StringFormat='Build {0}'}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding SystemInfo.Architecture}" VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="Laufwerk " FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SystemInfo.DriveLetter}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="Kapazit&#xE4;t: " FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SystemInfo.TotalSizeText}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <TextBlock Text="Frei: " FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SystemInfo.FreeSpaceText}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text=" (" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SystemInfo.FreePercentText}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text=")" FontSize="13" VerticalAlignment="Center"/>
                    <Border Margin="8,0,0,0" Padding="8,2,8,2" CornerRadius="4"
                            VerticalAlignment="Center"
                            BorderThickness="1"
                            BorderBrush="{Binding SystemInfo.IsAdmin, Converter={StaticResource AdminFgConverter}}"
                            Background="{Binding SystemInfo.IsAdmin, Converter={StaticResource AdminBgConverter}}">
                        <TextBlock Text="{Binding SystemInfo.IsAdmin, Converter={StaticResource AdminTextConverter}}"
                                   FontSize="11" FontWeight="Bold"
                                   TextAlignment="Center"
                                   Foreground="{Binding SystemInfo.IsAdmin, Converter={StaticResource AdminFgConverter}}"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Profile and Control Bar -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,15,0">
                    <TextBlock Text="Bereinigungsprofil:" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="ProfileComboBox" ItemsSource="{Binding Profiles}" SelectedIndex="{Binding SelectedProfileIndex}"
                              Width="200" Height="28" VerticalAlignment="Center"
                              Style="{DynamicResource ComboBoxStyle}"
                              DropDownOpened="OnComboBoxDropDownOpened">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding RecommendationText}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,8,0">
                    <Button Content="&#x1F50D; Analysieren"
                            Width="120" Height="32" Margin="0,0,8,0"
                            Style="{DynamicResource ActionButtonStyle}"
                            Click="OnAnalyzeClick"/>
                    <Button x:Name="StartButton"
                            Width="140" Height="32"
                            Style="{DynamicResource AccentButtonStyle}"
                            Foreground="White"
                            Click="OnStartCleanupClick"/>
                </StackPanel>
                <Button Grid.Column="3" Content="&#x2716; Abbrechen"
                        Width="110" Height="32" IsEnabled="{Binding IsRunning}"
                        Style="{DynamicResource WarningButtonStyle}"
                        Click="OnCancelClick"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Cleanup Tree -->
            <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding CleanupItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,2">
                                    <StackPanel Orientation="Horizontal" Margin="0,3">
                                        <CheckBox IsChecked="{Binding IsChecked}" IsThreeState="{Binding HasChildren}"
                                                  FontWeight="Bold" FontSize="14" Content="{Binding Name}"/>
                                        <Button Content="&#x2139;" FontSize="9" Width="17" Height="17" Padding="0" Margin="4,0,0,0"
                                                Style="{DynamicResource IconButtonStyle}"
                                                Tag="{Binding}"
                                                Visibility="{Binding InfoText, Converter={StaticResource StringNotEmptyConverter}}"
                                                Click="OnInfoButtonClick"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding IrreversibleWarning}" TextWrapping="Wrap"
                                               FontSize="11" Foreground="#BF360C" FontWeight="Bold"
                                               Margin="24,2,0,2"
                                               Visibility="{Binding IsIrreversible, Converter={StaticResource BoolToVisConverter}}"/>
                                    <ItemsControl ItemsSource="{Binding Children}" Margin="20,0,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                                        <CheckBox IsChecked="{Binding IsChecked}" Content="{Binding Name}"/>
                                                        <Button Content="&#x2139;" FontSize="8" Width="14" Height="14" Padding="0" Margin="4,0,0,0"
                                                                Style="{DynamicResource IconButtonStyle}"
                                                                Tag="{Binding}"
                                                                Visibility="{Binding InfoText, Converter={StaticResource StringNotEmptyConverter}}"
                                                                Click="OnInfoButtonClick"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding IrreversibleWarning}" TextWrapping="Wrap"
                                                               FontSize="11" Foreground="#BF360C" FontWeight="Bold"
                                                               Margin="24,2,0,2"
                                                               Visibility="{Binding IsIrreversible, Converter={StaticResource BoolToVisConverter}}"/>
                                                    <ItemsControl ItemsSource="{Binding Children}" Margin="20,0,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                    <CheckBox IsChecked="{Binding IsChecked}" Content="{Binding Name}"/>
                                                                    <Button Content="&#x2139;" FontSize="8" Width="14" Height="14" Padding="0" Margin="4,0,0,0"
                                                                            Style="{DynamicResource IconButtonStyle}"
                                                                            Tag="{Binding}"
                                                                            Visibility="{Binding InfoText, Converter={StaticResource StringNotEmptyConverter}}"
                                                                            Click="OnInfoButtonClick"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Right Panel -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Progress -->
                <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,4">
                    <StackPanel>
                        <TextBlock Text="Bereinigungs&#xFC;bersicht" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" FontSize="12" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding CurrentAction}" TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,5"/>
                        <ProgressBar Value="{Binding ProgressPercent}" Height="8" Margin="0,0,0,2" Foreground="{DynamicResource AccentBrush}"/>
                        <TextBlock Text="{Binding ProgressPercentText}" FontSize="11" HorizontalAlignment="Right" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Log -->
                <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="Protokoll" FontWeight="Bold" FontSize="13" Margin="0,0,10,4"/>
                            <Button Content="&#x1F4CB; Exportieren" FontSize="11" Height="24" Padding="8,0"
                                    Style="{DynamicResource SmallButtonStyle}"
                                    Click="OnExportClick"/>
                        </StackPanel>
                        <ListBox x:Name="LogListBox" Grid.Row="1" ItemsSource="{Binding LogEntries}" FontFamily="Consolas" FontSize="11"
                                 BorderThickness="0" VirtualizingPanel.ScrollUnit="Item">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="1,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="58"/>
                                                <ColumnDefinition Width="48"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Timestamp}"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding LevelPrefix}"
                                                       Foreground="{Binding Level, Converter={StaticResource LogLevelConverter}}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Message}" TextWrapping="NoWrap"
                                                       Margin="{Binding Indent, Converter={StaticResource IndentConverter}}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Result Panel -->
        <Border Grid.Row="4" Background="#E8F5E9" BorderBrush="#66BB6A" BorderThickness="1" CornerRadius="6"
                Padding="12" Margin="0,0,0,8"
                Visibility="{Binding IsResultVisible, Converter={StaticResource BoolToVisConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="&#x2705; Bereinigung abgeschlossen" FontSize="16" FontWeight="Bold" Foreground="#2E7D32" Margin="0,0,20,0"/>
                    <TextBlock Text="{Binding LastResult.FreeSpaceBeforeText, StringFormat='Vorher: {0}'}" FontSize="13" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <TextBlock Text="&#x2192;" FontSize="16" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <TextBlock Text="{Binding LastResult.FreeSpaceAfterText, StringFormat='Nachher: {0}'}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Foreground="#2E7D32" Margin="0,0,15,0"/>
                    <TextBlock Text="{Binding LastResult.TotalFreedText, StringFormat='Freigegeben: {0}'}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Foreground="#1565C0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="&#x2716;" Width="24" Height="24" FontSize="12"
                        Style="{DynamicResource IconButtonStyle}"
                        Click="OnCloseResultClick"/>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="6" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="4" Padding="0">
            <StatusBar Background="Transparent" BorderThickness="0" Padding="8,4">
                <StatusBarItem>
                    <TextBlock Text="{Binding StatusText}" FontSize="11"/>
                </StatusBarItem>
                <StatusBarItem HorizontalAlignment="Right">
                    <TextBlock Text="{Binding AppVersion}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StatusBarItem>
            </StatusBar>
        </Border>

        <!-- Info Popup -->
        <Popup x:Name="InfoPopup" StaysOpen="False" Placement="Right"
               AllowsTransparency="True" PopupAnimation="Fade"
               Closed="OnInfoPopupClosed">
            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="12"
                    MaxWidth="350" MaxHeight="350"
                    Mouse.MouseEnter="OnInfoPopupMouseEnter"
                    Mouse.MouseLeave="OnInfoPopupMouseLeave">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="InfoPopupText" TextWrapping="Wrap" FontSize="12"
                               Foreground="{DynamicResource TextBrush}"/>
                </ScrollViewer>
            </Border>
        </Popup>
    </Grid>
</Window>
