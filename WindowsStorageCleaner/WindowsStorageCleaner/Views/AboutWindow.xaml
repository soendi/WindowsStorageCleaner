<Window x:Class="WindowsStorageCleaner.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ueber Windows Storage Cleaner"
        Width="400" Height="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Window.Resources>
        <ResourceDictionary>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="&#x1F5C2;" FontSize="32" Margin="0,0,10,0"/>
            <StackPanel>
                <TextBlock Text="Windows Storage Cleaner" FontSize="20" FontWeight="Bold"/>
                <TextBlock x:Name="VersionText" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}"/>
            </StackPanel>
        </StackPanel>

        <Separator Grid.Row="1" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="2" Text="Professionelle Windows-Speicherplatzbereinigung" FontSize="14" Margin="0,0,0,10"/>
        <TextBlock Grid.Row="3" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,10">
            <Run Text="Entwickelt mit "/>
            <Run Text="C# / WPF / .NET 8" FontWeight="Bold"/>
            <Run Text="&#x0a;"/>
            <Run Text="MVVM-Architektur"/>
            <Run Text="&#x0a;&#x0a;"/>
            <Run Text="Diese Software bereinigt tempor&#xE4;re Dateien, System-Caches und nicht ben&#xF6;tigte Komponenten, um Speicherplatz freizugeben."/>
            <Run Text="&#x0a;&#x0a;"/>
            <Run Text="&#xA9; 2026 Windows Storage Cleaner" FontSize="11"/>
        </TextBlock>

        <Button Grid.Row="5" Content="Schlie&#xDF;en" Width="100" Height="32"
                HorizontalAlignment="Right" Click="OnCloseClick"/>
    </Grid>
</Window>
