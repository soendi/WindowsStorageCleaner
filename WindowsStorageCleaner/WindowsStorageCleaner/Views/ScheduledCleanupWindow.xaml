<Window x:Class="WindowsStorageCleaner.Views.ScheduledCleanupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Automatische Speicherplatzbereinigung"
        Width="480" MinHeight="320" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Automatische Bereinigung" FontSize="20" FontWeight="Bold"
                   Foreground="{DynamicResource ErrorBrush}" Margin="0,0,0,5"/>

        <TextBlock Grid.Row="1" Text="Richten Sie eine regelmäßige Speicherplatzbereinigung ein. Die Bereinigung läuft automatisch im Hintergrund um 10:00 Uhr." 
                   TextWrapping="Wrap" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="2" Text="Häufigkeit:" FontWeight="Bold" Margin="0,0,0,4"/>
        <ComboBox x:Name="FrequencyCombo" Grid.Row="3" Height="30" FontSize="13"
                  SelectedIndex="0" Style="{DynamicResource ComboBoxStyle}" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="4" Text="Profil:" FontWeight="Bold" Margin="0,0,0,4"/>
        <ComboBox x:Name="ProfileCombo" Grid.Row="5" Height="30" FontSize="13"
                  SelectedIndex="5" Style="{DynamicResource ComboBoxStyle}" Margin="0,0,0,20"/>

        <TextBlock x:Name="StatusText" Grid.Row="6" FontSize="13" FontWeight="Bold" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="InstallBtn" Content="Einrichten" Width="100" Height="32" Margin="0,0,10,0"
                    Style="{DynamicResource AccentButtonStyle}" Click="OnInstallClick"/>
            <Button x:Name="RemoveBtn" Content="Deaktivieren" Width="110" Height="32" Margin="0,0,10,0"
                    Style="{DynamicResource WarningButtonStyle}" Click="OnRemoveClick"/>
            <Button Content="Schließen" Width="100" Height="32"
                    Style="{DynamicResource ActionButtonStyle}" Click="OnCloseClick"/>
        </StackPanel>
    </Grid>
</Window> 