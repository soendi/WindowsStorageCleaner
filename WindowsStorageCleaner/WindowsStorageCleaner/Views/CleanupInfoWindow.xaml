<Window x:Class="WindowsStorageCleaner.Views.CleanupInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Alle Bereinigungspunkte im Überblick"
        Width="650" Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,8">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding InfoText}" TextWrapping="Wrap" FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}" LineHeight="18"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        <Button Grid.Row="1" Content="Schließen" Width="100" Height="32"
                HorizontalAlignment="Right" Margin="0,10,0,0" Click="OnCloseClick"
                Style="{DynamicResource ActionButtonStyle}"/>
    </Grid>
</Window>
